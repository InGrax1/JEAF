# ============================================================
# JEAF Backend — Variables de entorno
# Copiar a .env y completar. NUNCA versionar el .env real.
# ============================================================

# Servidor
NODE_ENV=development
PORT=3000

# CORS: orígenes autorizados separados por coma (panel web)
CORS_ORIGINS=http://localhost:5173

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=jeaf

# JWT (usar secretos largos y aleatorios, distintos entre sí)
JWT_ACCESS_SECRET=cambiar_por_secreto_aleatorio_largo
JWT_REFRESH_SECRET=cambiar_por_otro_secreto_aleatorio_largo
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Zona horaria local de la iglesia (conversión UTC <-> local se hace en backend)
LOCAL_TIMEZONE=America/Mexico_City

# Nombre de la iglesia (encabezado de reportes PDF/Excel)
IGLESIA_NOMBRE=JEAF — Gestión Financiera

# Logotipo opcional para el PDF: colocar el archivo en Backend/assets/logo.png

# SMTP para recuperación de contraseña (opcional en desarrollo: si falta,
# el código se imprime en consola en vez de enviarse; en producción es obligatorio).
# Ejemplo con Gmail: host smtp.gmail.com, puerto 587, usuario tu correo,
# contraseña una "contraseña de aplicación" (no la contraseña normal de la cuenta).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=JEAF <no-responder@jeaf.local>
