{
  "name": "jeaf-backend",
  "version": "0.5.0",
  "description": "JEAF — API REST de gestión financiera y contable para iglesias",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:int": "vitest run -c vitest.config.integration.js",
